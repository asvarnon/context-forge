{
  "name": "context-forge",
  "displayName": "Context Forge",
  "description": "Compaction-aware persistent memory for AI coding agents",
  "version": "0.1.0",
  "publisher": "asvarnon",
  "repository": {
    "type": "git",
    "url": "https://github.com/asvarnon/context-forge"
  },
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": ["Other"],
  "enabledApiProposals": [
    "chatContextProvider"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "context-forge.saveContext",
        "title": "Context Forge: Save Context"
      },
      {
        "command": "context-forge.clearContext",
        "title": "Context Forge: Clear Context"
      }
    ]
  },
  "scripts": {
    "build:native": "cargo build -p cf-napi --manifest-path ../Cargo.toml && node -e \"const p=process.platform,f=p==='win32'?'cf_napi.dll':p==='darwin'?'libcf_napi.dylib':'libcf_napi.so';require('fs').copyFileSync('../target/debug/'+f,'./cf_napi.node')\"",
    "compile": "npm run build:native && tsc -p ./",
    "watch": "tsc -watch -p ./",
    "postinstall": "npx @vscode/dts dev"
  },
  "devDependencies": {
    "@types/node": "20.x",
    "@types/vscode": "^1.109.0",
    "typescript": "^5.8.3"
  }
}
