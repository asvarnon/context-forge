{
  "name": "context-forge",
  "displayName": "Context Forge",
  "description": "Compaction-aware persistent memory for AI coding agents",
  "version": "0.1.0",
  "publisher": "asvarnon",
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": ["Other"],
  "enabledApiProposals": [
    "chatHooks",
    "chatContextProvider"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "context-forge.saveContext",
        "title": "Context Forge: Save Context"
      },
      {
        "command": "context-forge.clearContext",
        "title": "Context Forge: Clear Context"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "postinstall": "npx @vscode/dts dev"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "@types/node": "20.x",
    "@types/vscode": "^1.108.0"
  }
}
